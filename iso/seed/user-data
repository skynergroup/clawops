#cloud-config
autoinstall:
  version: 1
  identity:
    hostname: clawops
    username: clawops
    # Replace with hashed password before production
    password: "$6$rounds=4096$example$exampleexampleexampleexampleexampleexampleexampleexampleexampleexample0"
  ssh:
    install-server: true
    allow-pw: true
  packages:
    - qemu-guest-agent
  storage:
    layout:
      name: direct
